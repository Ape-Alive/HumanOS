{
  "name": "@humanos/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "HumanOS Electron desktop — Vue 3 + JS (no TypeScript)",
  "main": "electron-main/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env ELECTRON_USE_DEV_SERVER=1 electron .",
    "dev:electron:open": "cross-env ELECTRON_USE_DEV_SERVER=1 electron .",
    "dev:electron:ctrl": "cross-env ELECTRON_USE_DEV_SERVER=1 HUMANOS_USER_DATA_SUFFIX=ctrl electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "copy:signal-server": "node scripts/copy-signal-server.js",
    "icons": "node scripts/generate-icons.js",
    "pack:clean-cache": "node scripts/clean-electron-cache.js",
    "pack:clean-cache:win": "node scripts/clean-electron-cache.js 33.4.11 win32",
    "build": "npm run copy:signal-server && vite build",
    "start": "npm run build && electron .",
    "preview:vite": "vite preview",
    "pack": "node scripts/pack.js",
    "pack:dir": "node scripts/pack.js dir",
    "pack:current": "node scripts/pack.js current",
    "pack:mac": "node scripts/pack.js mac",
    "pack:mac:arm64": "node scripts/pack.js mac:arm64",
    "pack:mac:x64": "node scripts/pack.js mac:x64",
    "pack:win": "node scripts/pack.js win",
    "pack:win:x64": "node scripts/pack.js win:x64",
    "pack:linux": "node scripts/pack.js linux",
    "pack:linux:x64": "node scripts/pack.js linux:x64",
    "pack:linux:arm64": "node scripts/pack.js linux:arm64",
    "pack:all": "node scripts/pack.js all"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.2",
    "docx": "^9.6.1",
    "lucide-vue-next": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.11.0",
    "vue": "^3.5.13",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.humanos.desktop",
    "productName": "HumanOS",
    "copyright": "Copyright © HumanOS",
    "electronVersion": "33.4.11",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "publish": null,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron-main/**/*",
      "preload/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "resources/signal-server",
        "to": "signal-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "HumanOS"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HumanOS"
    },
    "linux": {
      "icon": "build/icons",
      "category": "Network",
      "maintainer": "HumanOS",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
