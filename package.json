{
  "name": "humanos",
  "private": true,
  "description": "WebRTC remote desktop + control code — monorepo (JS only, no TypeScript)",
  "workspaces": [
    "backend/signal-server",
    "backend/signal-server-worker",
    "frontend/desktop"
  ],
  "scripts": {
    "dev:signal": "npm run dev -w @humanos/signal-server",
    "dev:signal:worker": "npm run dev -w @humanos/signal-server-worker",
    "start:signal": "npm run start -w @humanos/signal-server",
    "deploy:signal:worker": "npm run deploy -w @humanos/signal-server-worker",
    "login:signal:worker": "npm run login -w @humanos/signal-server-worker",
    "dev:desktop": "npm run dev -w @humanos/desktop",
    "dev:desktop:vite": "npm run dev:vite -w @humanos/desktop",
    "dev:desktop:electron": "npm run dev:electron -w @humanos/desktop",
    "dev:desktop:electron:open": "npm run dev:electron:open -w @humanos/desktop",
    "dev:desktop:electron:ctrl": "npm run dev:electron:ctrl -w @humanos/desktop",
    "start:desktop": "npm run start -w @humanos/desktop",
    "pack:desktop": "npm run pack -w @humanos/desktop",
    "pack:desktop:dir": "npm run pack:dir -w @humanos/desktop",
    "pack:desktop:mac": "npm run pack:mac -w @humanos/desktop",
    "pack:desktop:mac:arm64": "npm run pack:mac:arm64 -w @humanos/desktop",
    "pack:desktop:mac:x64": "npm run pack:mac:x64 -w @humanos/desktop",
    "pack:desktop:win": "npm run pack:win -w @humanos/desktop",
    "pack:desktop:win:x64": "npm run pack:win:x64 -w @humanos/desktop",
    "pack:desktop:linux": "npm run pack:linux -w @humanos/desktop",
    "pack:desktop:linux:x64": "npm run pack:linux:x64 -w @humanos/desktop",
    "pack:desktop:linux:arm64": "npm run pack:linux:arm64 -w @humanos/desktop",
    "pack:desktop:all": "npm run pack:all -w @humanos/desktop",
    "pack": "npm run pack:desktop",
    "pack:dir": "npm run pack:desktop:dir",
    "pack:mac": "npm run pack:desktop:mac",
    "pack:mac:arm64": "npm run pack:desktop:mac:arm64",
    "pack:mac:x64": "npm run pack:desktop:mac:x64",
    "pack:win": "npm run pack:desktop:win",
    "pack:win:x64": "npm run pack:desktop:win:x64",
    "pack:linux": "npm run pack:desktop:linux",
    "pack:linux:x64": "npm run pack:desktop:linux:x64",
    "pack:linux:arm64": "npm run pack:desktop:linux:arm64",
    "pack:all": "npm run pack:desktop:all",
    "pack:clean-cache": "npm run pack:clean-cache -w @humanos/desktop",
    "pack:clean-cache:win": "npm run pack:clean-cache:win -w @humanos/desktop"
  },
  "engines": {
    "node": ">=18"
  }
}
